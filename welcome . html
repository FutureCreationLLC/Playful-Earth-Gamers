<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Playful Earth Gamers</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root {
    --accent: #00d4aa;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: "Inter", sans-serif;
    height: 100vh;
    overflow: hidden;
    background: black;
}

/* LOADING */
#loading {
    position: fixed;
    inset: 0;
    background: black;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    color: white;
}

#loading h1 {
    color: var(--accent);
    letter-spacing: 3px;
}

/* SLIDES */
.slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.8s ease;
}

.slide::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.60);
}

.slide.active {
    opacity: 1;
}

/* PANEL */
.panel {
    position: absolute;
    top: 40px;
    right: 40px;
    width: 480px;
    max-width: 90%;
    padding: 22px;
    background: rgba(10,10,25,0.65);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(0,212,170,0.25);
    border-radius: 18px;
    color: white;
}

h1 {
    color: var(--accent);
    font-size: 1.4rem;
    margin-bottom: 10px;
}

p, div {
    font-size: 0.95rem;
    line-height: 1.6;
    white-space: pre-line;
}

/* NAV */
.nav {
    position: fixed;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
}

button {
    padding: 10px 20px;
    border-radius: 40px;
    border: 1px solid var(--accent);
    background: rgba(255,255,255,0.08);
    color: white;
    cursor: pointer;
}

button:hover {
    background: var(--accent);
    color: black;
}

.primary {
    background: var(--accent);
    color: black;
    border: none;
}
</style>
</head>

<body>

<!-- LOADING SCREEN -->
<div id="loading">
    <h1>PLAYFUL EARTH GAMERS</h1>
    <p>Loading experience...</p>
</div>

<!-- SLIDE 1 -->
<div class="slide active" style="background-image:url('https://images.unsplash.com/photo-1551105370-1f2d4c7c3f8a')">
